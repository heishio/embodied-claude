{
  "env": {
    "MCP_TIMEOUT": "30000"
  },
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "mcp__wifi-cam__see|mcp__usb-webcam__see",
        "hooks": [
          {
            "type": "command",
            "command": ".claude/hooks/run-see-embed.cmd",
            "timeout": 35
          }
        ]
      },
      {
        "matcher": "mcp__tts__say",
        "hooks": [
          {
            "type": "command",
            "command": ".claude/hooks/run-say-buffer.cmd",
            "timeout": 5
          }
        ]
      },
      {
        "matcher": "mcp__memory__diary",
        "hooks": [
          {
            "type": "command",
            "command": ".claude/hooks/run-diary-wave.cmd",
            "timeout": 10
          }
        ]
      }
    ],
    "Stop": [],
    "SessionEnd": [
      {
        "hooks": [
          {
            "type": "command",
            "command": ".claude/hooks/run-session-end-buffer.cmd",
            "timeout": 30
          },
          {
            "type": "command",
            "command": ".claude/hooks/run-consolidate-wave.cmd",
            "timeout": 30
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": ".claude/hooks/run-interoception.cmd",
            "timeout": 15
          },
          {
            "type": "command",
            "command": ".claude/hooks/run-keyword-buffer.cmd",
            "timeout": 15
          },
          {
            "type": "command",
            "command": ".claude/hooks/run-passive-vision.cmd",
            "timeout": 5
          },
          {
            "type": "command",
            "command": ".claude/hooks/run-session-wave-v2.cmd",
            "timeout": 15
          }
        ]
      }
    ]
  }
}
